// This source code is subject to the terms of the Mozilla Public License 2.0
// © MARSI — Macro-Adjusted RSI Indicator
// https://github.com/2003XACH/macro-momentum-indicator
//
// Combines classic RSI with a live macro regime detector (VIX + DXY)
// to dynamically shift overbought/oversold thresholds based on market stress.
//
//  Regime     Condition                    OB / OS
//  Risk-ON    VIX < 18  AND DXY falling   75 / 25
//  Neutral    Default                      70 / 30
//  Risk-OFF   VIX > 25  AND DXY rising    60 / 40

//@version=6
indicator(title="MARSI — Macro-Adjusted RSI", shorttitle="MARSI", overlay=false)

// ─── INPUTS ─────────────────────────────────────────────────────────────────
rsiLength     = input.int(14,    "RSI Length",          minval=2)
rsiSource     = input.source(close, "RSI Source")

vixHigh       = input.float(25.0, "VIX Risk-OFF Level", minval=1.0, step=0.5,
                    tooltip="VIX above this → higher stress regime")
vixLow        = input.float(18.0, "VIX Risk-ON Level",  minval=1.0, step=0.5,
                    tooltip="VIX below this → lower stress / risk-on regime")
dxyMaLen      = input.int(20,   "DXY Trend MA Length",  minval=5,
                    tooltip="DXY above its MA = rising dollar (risk-off signal)")

showMacroRate = input.bool(false, "Show Rate-Hike Regime Layer",
                    tooltip="Overlay US interest rate data to detect hiking cycles")
showLabels    = input.bool(true,  "Show Regime Labels on Chart")
showBg        = input.bool(true,  "Show Background Color")

// ─── MACRO DATA ──────────────────────────────────────────────────────────────
vixClose = request.security("CBOE:VIX",         timeframe.period, close, ignore_invalid_symbol=true)
dxyClose = request.security("TVC:DXY",          timeframe.period, close, ignore_invalid_symbol=true)
usIntr   = request.security("ECONOMICS:USINTR", "1M",             close, ignore_invalid_symbol=true)

dxyMa     = ta.sma(dxyClose, dxyMaLen)
dxyRising = dxyClose > dxyMa

// ─── REGIME DETECTION ────────────────────────────────────────────────────────
// Three-state regime: -1 = Risk-OFF, 0 = Neutral, 1 = Risk-ON
regime = switch
    vixClose > vixHigh and dxyRising     => -1
    vixClose < vixLow  and not dxyRising =>  1
    =>                                       0

// Dynamic thresholds
obLevel = regime == 1 ? 75 : regime == -1 ? 60 : 70
osLevel = regime == 1 ? 25 : regime == -1 ? 40 : 30

// ─── RSI CALCULATION ─────────────────────────────────────────────────────────
rsiValue = ta.rsi(rsiSource, rsiLength)

// ─── RATE-HIKE LAYER (optional) ──────────────────────────────────────────────
// Flag when rates are rising (hiking cycle) — further tightens conditions
rateHiking = showMacroRate and not na(usIntr) and usIntr > usIntr[1]

// ─── COLOURS ─────────────────────────────────────────────────────────────────
colorRsiLine = switch
    rsiValue >= obLevel => color.new(color.red,   0)
    rsiValue <= osLevel => color.new(color.green, 0)
    =>                     color.new(color.blue,  0)

bgColorRaw = switch
    regime ==  1 => color.new(color.green, 88)
    regime == -1 => color.new(color.red,   88)
    =>              color.new(color.gray,  92)

bgColor = rateHiking ? color.new(color.orange, 85) : bgColorRaw

// ─── PLOTS ───────────────────────────────────────────────────────────────────
bgcolor(showBg ? bgColor : na, title="Macro Regime Background")

plot(rsiValue, title="MARSI", color=colorRsiLine, linewidth=2)

obPlot  = plot(obLevel, title="Overbought", color=color.new(color.red,   30), linewidth=1, style=plot.style_line)
osPlot  = plot(osLevel, title="Oversold",   color=color.new(color.green, 30), linewidth=1, style=plot.style_line)
midPlot = plot(50,      title="Midline",    color=color.new(color.gray,  50), linewidth=1, style=plot.style_line)

fill(obPlot, midPlot, top_value=100, bottom_value=50,
     top_color    = color.new(color.red,   90),
     bottom_color = color.new(color.red,   100),
     title="Overbought Zone Fill")

fill(osPlot, midPlot, top_value=50, bottom_value=0,
     top_color    = color.new(color.green, 100),
     bottom_color = color.new(color.green, 90),
     title="Oversold Zone Fill")

// ─── REGIME LABELS ───────────────────────────────────────────────────────────
regimeLabel = switch
    regime ==  1 => "Risk-ON  ▲"
    regime == -1 => "Risk-OFF ▼"
    =>              "Neutral  ●"

regimeLabelColor = switch
    regime ==  1 => color.new(color.green, 0)
    regime == -1 => color.new(color.red,   0)
    =>              color.new(color.gray,  0)

if showLabels and barstate.islast
    label.new(bar_index, rsiValue,
              text      = regimeLabel + (rateHiking ? "\nRate Hiking ↑" : ""),
              style     = label.style_label_left,
              color     = regimeLabelColor,
              textcolor = color.white,
              size      = size.small)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
alertcondition(ta.crossunder(rsiValue, osLevel),
    title="MARSI Oversold Cross",
    message="MARSI crossed below oversold threshold ({{ticker}}, regime={{plot_0}})")

alertcondition(ta.crossover(rsiValue, obLevel),
    title="MARSI Overbought Cross",
    message="MARSI crossed above overbought threshold ({{ticker}}, regime={{plot_0}})")

alertcondition(regime == -1 and ta.crossunder(rsiValue, osLevel),
    title="MARSI Oversold in Risk-OFF Regime",
    message="Strong buy signal: MARSI oversold during Risk-OFF macro regime ({{ticker}})")

// ─── TABLE: LIVE MACRO DASHBOARD ─────────────────────────────────────────────
if barstate.islast
    var table dash = table.new(position.top_right, 2, 5,
         border_width=1, border_color=color.new(color.gray, 60),
         bgcolor=color.new(color.black, 80))

    table.cell(dash, 0, 0, "MARSI Dashboard", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20))
    table.cell(dash, 1, 0, "",                 bgcolor=color.new(color.navy, 20))

    table.cell(dash, 0, 1, "RSI",    text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(math.round(rsiValue, 1)), text_color=colorRsiLine, text_size=size.small)

    vixColor = vixClose > vixHigh ? color.new(color.red, 0) : vixClose < vixLow ? color.new(color.green, 0) : color.new(color.white, 0)
    table.cell(dash, 0, 2, "VIX",    text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(math.round(vixClose, 2)), text_color=vixColor, text_size=size.small)

    dxyColor = dxyRising ? color.new(color.red, 0) : color.new(color.green, 0)
    table.cell(dash, 0, 3, "DXY",    text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(math.round(dxyClose, 2)) + (dxyRising ? " ↑" : " ↓"), text_color=dxyColor, text_size=size.small)

    table.cell(dash, 0, 4, "Regime", text_color=color.silver, text_size=size.small)
    table.cell(dash, 1, 4, regimeLabel, text_color=regimeLabelColor, text_size=size.small)
